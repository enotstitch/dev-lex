{
  "name": "dev-lex",
  "version": "1.0.0",
  "description": "Telegram-бот для изучения технического английского языка разработчиками.",
  "type": "module",
  "scripts": {
    "start": "node src/bot.js",
    "lint": "eslint src",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": "eslint --no-cache --fix --max-warnings=0",
    "*.{js,css,md}": "prettier --write"
  },
  "keywords": [
    "telegram",
    "bot",
    "grammy",
    "javascript",
    "english",
    "developer"
  ],
  "author": "Anna Kessler",
  "license": "MIT",
  "homepage": "https://github.com/enotstitch/dev-lex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enotstitch/dev-lex.git"
  },
  "bugs": {
    "url": "https://github.com/enotstitch/dev-lex/issues"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.5"
  }
}
